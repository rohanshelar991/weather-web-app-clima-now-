# ClimaNow Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenWeatherMap API Key (Required)
# Get your free API key from: https://openweathermap.org/api
REACT_APP_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# AirVisual API Key (Optional - for air quality data)
# Get your API key from: https://www.iqair.com/air-pollution-data-api
REACT_APP_AIRVISUAL_API_KEY=your_airvisual_api_key_here

# NASA API Key (Optional - for astronomical data)
# Get your API key from: https://api.nasa.gov/
REACT_APP_NASA_API_KEY=your_nasa_api_key_here

# App Configuration
REACT_APP_APP_NAME=ClimaNow
REACT_APP_APP_VERSION=1.0.0

# Debug Mode (Optional)
REACT_APP_DEBUG_MODE=false

# Analytics (Optional)
REACT_APP_GOOGLE_ANALYTICS_ID=your_ga_id_here

# Push Notifications (Optional)
REACT_APP_VAPID_PUBLIC_KEY=your_vapid_public_key_here
